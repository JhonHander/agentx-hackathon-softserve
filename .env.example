# -------------------------------
# EverShop core app
# -------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable

# Optional host port overrides for docker-compose.yml
APP_HOST_PORT=3000
POSTGRES_HOST_PORT=5432

# App -> Orchestrator proxy target
RAG_ORCHESTRATOR_MESSAGE_URL=http://rag-api:8000/agents/orchestrator/message
RAG_ORCHESTRATOR_TIMEOUT_MS=30000

# -------------------------------
# OpenAI / embeddings
# -------------------------------
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -------------------------------
# RAG behavior
# -------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=evershop_codebase
RAG_REPO_PATH=/workspace/repo
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_MAX_FILE_BYTES=800000
RAG_LOCAL_FALLBACK_ENABLED=true
ORCHESTRATOR_MODEL=gpt-4.1-mini
ORCHESTRATOR_TEMPERATURE=0.1
ORCHESTRATOR_RAG_TOP_K=8

# -------------------------------
# Incident API integration
# -------------------------------
INCIDENT_API_URL=http://app:3000/api/incidents
INCIDENT_RECOMMENDATION_API_URL=http://app:3000/api/incidents/recommendations
INCIDENT_API_TIMEOUT_SECONDS=20

# -------------------------------
# Jira integration
# -------------------------------
JIRA_MODE=auto
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your_jira_email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=PROJ
JIRA_ISSUE_TYPE=Bug
JIRA_TIMEOUT_SECONDS=20

# MCP Jira options (used when JIRA_MODE=auto or mcp)
JIRA_MCP_ENABLED=true
JIRA_MCP_TRANSPORT=streamable_http
JIRA_MCP_URL=https://mcp.atlassian.com/v1/mcp
JIRA_MCP_BEARER_TOKEN=
JIRA_MCP_HEADERS_JSON=
JIRA_MCP_TOOL_CREATE_ISSUE=createJiraIssue
JIRA_MCP_TIMEOUT_SECONDS=25
JIRA_MCP_COMMAND=
JIRA_MCP_ARGS=-y,mcp-remote,https://mcp.atlassian.com/v1/mcp
JIRA_MCP_CWD=
JIRA_MCP_CREATE_ISSUE_ARGS_JSON=
JIRA_CLOUD_ID=

# Jira webhook options
JIRA_WEBHOOK_ENABLED=true
JIRA_WEBHOOK_SECRET=replace_with_webhook_shared_secret
JIRA_DONE_STATUS_NAMES=done,resolved,closed,finalizado,terminado
JIRA_TICKET_REGISTRY_PATH=/app/data/jira_ticket_registry.json

# -------------------------------
# Reporter email notifications
# -------------------------------
REPORTER_EMAIL_NOTIFICATIONS_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=EverShop Support
SMTP_REPLY_TO=support@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
