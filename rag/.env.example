OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
INCIDENT_API_URL=http://app:3000/api/incidents
INCIDENT_RECOMMENDATION_API_URL=http://app:3000/api/incidents/recommendations
INCIDENT_API_TIMEOUT_SECONDS=20
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=evershop_codebase
RAG_REPO_PATH=/absolute/path/to/evershop
ORCHESTRATOR_MODEL=gpt-4.1-mini
ORCHESTRATOR_TEMPERATURE=0.1
ORCHESTRATOR_RAG_TOP_K=8
RAG_LOCAL_FALLBACK_ENABLED=true
JIRA_BASE_URL=https://nicolashoyosdev.atlassian.net/
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=IA
JIRA_ISSUE_TYPE=Bug
JIRA_TIMEOUT_SECONDS=20
JIRA_MODE=auto
JIRA_MCP_ENABLED=true
JIRA_MCP_TRANSPORT=streamable_http
JIRA_MCP_URL=https://mcp.atlassian.com/v1/mcp
JIRA_MCP_BEARER_TOKEN=
JIRA_MCP_HEADERS_JSON=
JIRA_MCP_TOOL_CREATE_ISSUE=createJiraIssue
JIRA_MCP_TIMEOUT_SECONDS=25
JIRA_MCP_COMMAND=
JIRA_MCP_ARGS=-y,mcp-remote,https://mcp.atlassian.com/v1/mcp
JIRA_MCP_CWD=
JIRA_MCP_CREATE_ISSUE_ARGS_JSON=
JIRA_CLOUD_ID=
JIRA_WEBHOOK_ENABLED=true
JIRA_WEBHOOK_SECRET=
JIRA_DONE_STATUS_NAMES=done,resolved,closed,finalizado,terminado
JIRA_TICKET_REGISTRY_PATH=
REPORTER_EMAIL_NOTIFICATIONS_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=EverShop Support
SMTP_REPLY_TO=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_MAX_FILE_BYTES=800000

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=pk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_ENABLED=true
